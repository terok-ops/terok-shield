# Fedora 43 — podman 5.8.x, pasta default, modern everything
FROM registry.fedoraproject.org/fedora:43

RUN dnf install -y \
    podman passt nftables slirp4netns fuse-overlayfs \
    python3 python3-pip \
    git curl \
    && dnf clean all

WORKDIR /src
