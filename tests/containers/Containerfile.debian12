# Debian 12 (Bookworm) — podman 4.3.1, slirp4netns only
FROM docker.io/library/debian:12

RUN apt-get update && apt-get install -y --no-install-recommends \
    podman slirp4netns nftables uidmap fuse-overlayfs \
    python3 \
    git curl ca-certificates dnsutils \
    && rm -rf /var/lib/apt/lists/*

# Debian 12 ships Python 3.11 — use uv to get 3.12+
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN uv python install 3.12

# Rootless test user with subordinate UID/GID ranges
RUN useradd -m testrunner \
    && echo "testrunner:100000:65536" >> /etc/subuid \
    && echo "testrunner:100000:65536" >> /etc/subgid \
    && mkdir -p /run/user/$(id -u testrunner) \
    && chown testrunner:testrunner /run/user/$(id -u testrunner)

# Configure podman for nested rootless operation
RUN mkdir -p /etc/containers \
    && printf '[storage]\ndriver = "overlay"\n\n[storage.options.overlay]\nmount_program = "/usr/bin/fuse-overlayfs"\nmountopt = "nodev,fsync=0"\n' \
        > /etc/containers/storage.conf \
    && printf '[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' \
        > /etc/containers/containers.conf

WORKDIR /src
